apiVersion: v1
kind: ServiceAccount
metadata:
  name: email-ruby
  namespace: arp
  annotations:
    eks.amazonaws.com/role-arn: arn:aws:iam::${AWS_ACCOUNT_ID}:role/arp-email
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: email-ruby
  namespace: arp
  labels:
    app: email-ruby
spec:
  replicas: 1
  selector:
    matchLabels:
      app: email-ruby
  template:
    metadata:
      labels:
        app: email-ruby
    spec:
      serviceAccountName: email-ruby
      containers:
        - name: email-ruby
          image: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/arp/email-ruby:latest
          imagePullPolicy: Always
          env:
            - name: TEMPORAL_ADDRESS
              value: temporal-frontend.temporal.svc:7233
            - name: TEMPORAL_NAMESPACE
              value: default
            - name: AWS_REGION
              value: ${AWS_REGION}
            # From address on the verified witski.com domain (MAIL FROM is
            # temporal-sandbox.witski.com). Domain verification covers subdomains.
            - name: SES_SENDER
              value: noreply@temporal-sandbox.witski.com
          resources:
            requests:
              cpu: 50m
              memory: 128Mi
            limits:
              memory: 256Mi
