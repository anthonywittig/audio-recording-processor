# The workflow worker hosts the processAudio workflow and polls the `workflow`
# task queue. It talks only to Temporal (no AWS), so no IRSA role is needed.
apiVersion: v1
kind: ServiceAccount
metadata:
  name: workflow-ts
  namespace: arp
---
apiVersion: apps/v1
kind: Deployment
metadata:
  name: workflow-ts
  namespace: arp
  labels:
    app: workflow-ts
spec:
  replicas: 1
  selector:
    matchLabels:
      app: workflow-ts
  template:
    metadata:
      labels:
        app: workflow-ts
    spec:
      serviceAccountName: workflow-ts
      containers:
        - name: workflow-ts
          image: ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/arp/workflow-ts:latest
          imagePullPolicy: Always
          env:
            - name: TEMPORAL_ADDRESS
              value: temporal-frontend.temporal.svc:7233
            - name: TEMPORAL_NAMESPACE
              value: default
          resources:
            requests:
              cpu: 100m
              memory: 256Mi
            limits:
              memory: 512Mi
