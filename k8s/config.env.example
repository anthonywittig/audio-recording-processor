# Copy to config.env (gitignored) if you want to render the worker manifests
# WITHOUT reading Terraform outputs. If config.env is absent, k8s/apply.sh reads
# these from `terraform -chdir=../infra/terraform/poc output` instead.
#
# NOTE: these are not secrets — an AWS account ID appears in every ARN and image
# reference. They're pulled out of the manifests so the manifests stay portable
# across accounts/regions, not for secrecy.
AWS_ACCOUNT_ID=000000000000
AWS_REGION=us-east-1
